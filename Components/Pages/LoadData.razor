@page "/load"
@inject CsvDataService DataService

<div class="mt-4" style="max-width:500px">
    @if (DataService.HasData)
    {
        <div class="alert alert-success mb-4">
            <strong>Data loaded.</strong> Load a new file below to replace it.
        </div>
    }

    <div class="drop-zone">
        <p class="fs-5 mb-2">Load <strong>presence_log.csv</strong></p>
        <form action="api/upload-csv" method="post" enctype="multipart/form-data">
            <label class="form-label text-muted small">Choose the CSV file</label>
            <input type="file" name="file" accept=".csv" class="form-control mb-3" />
            <button type="submit" class="btn btn-primary">Load File</button>
        </form>
    </div>
</div>
