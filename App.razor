<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ML</title>
    <base href="/pres/" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        // ── Submit a GET form via window.location (bypasses Blazor enhanced-nav interception) ──
        window.submitFilter = function (formId) {
            var f = document.getElementById(formId);
            if (!f) return;
            var qs = new URLSearchParams(new FormData(f)).toString();
            window.location.href = window.location.pathname + '?' + qs;
        };

        // ── User-filter dropdown helpers (plain JS, no Blazor circuit needed) ──
        window.uf = {
            toggle: function (menuId) {
                var m = document.getElementById(menuId);
                if (m) m.style.display = m.style.display === 'none' ? 'block' : 'none';
            },
            all: function (menuId) {
                document.querySelectorAll('#' + menuId + ' .uf-cb')
                    .forEach(function (cb) { cb.checked = true; });
            },
            none: function (menuId) {
                document.querySelectorAll('#' + menuId + ' .uf-cb')
                    .forEach(function (cb) { cb.checked = false; });
            },
            apply: function (menuId, hiddenId, formId) {
                var ids = Array.from(document.querySelectorAll('#' + menuId + ' .uf-cb:checked'))
                    .map(function (cb) { return cb.dataset.uid; });
                var h = document.getElementById(hiddenId);
                if (h) h.value = ids.join(',');
                window.submitFilter(formId);
            }
        };
        document.addEventListener('click', function (e) {
            document.querySelectorAll('.uf-menu').forEach(function (m) {
                var wrapper = m.closest('.uf-wrapper');
                if (wrapper && !wrapper.contains(e.target)) m.style.display = 'none';
            });
        });

        window.presDownload = (filename, base64) => {
            const a = document.createElement('a');
            a.href = 'data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,' + base64;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        };

        window.presUploadCsvById = async (inputId) => {
            const el = document.getElementById(inputId);
            if (!el) return 'no_element';
            const file = el.files[0];
            if (!file) return 'no_file';
            const formData = new FormData();
            formData.append('file', file);
            try {
                const resp = await fetch('/pres/api/upload-csv', { method: 'POST', body: formData });
                return resp.ok ? 'ok' : 'error_' + resp.status;
            } catch (e) {
                return 'fetch_error: ' + e.message;
            }
        };

    </script>
</body>
</html>
